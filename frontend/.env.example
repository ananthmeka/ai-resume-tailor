# =============================================================================
# FRONTEND environment (Vite / React)
# Copy to:  ai-resume-tailor/frontend/.env
# Used when: npm run dev / npm run build (Vercel reads these as env vars)
#
# Backend secrets (GROQ_API_KEY, APP_API_KEY for server) go in ROOT .env
# or Railway — NOT here except VITE_API_KEY for browser → API auth.
# Never commit .env (add frontend/.env to gitignore).
# =============================================================================

# Local dev: leave BOTH unset — Vite proxies /api to http://localhost:8080
# VITE_API_BASE_URL=
# VITE_API_KEY=

# Production / testing against Railway (same as Vercel Production settings):
# VITE_API_BASE_URL=https://your-service.up.railway.app
# VITE_API_KEY=<same 64-char hex string as backend APP_API_KEY>

VITE_API_BASE_URL=
VITE_API_KEY=
