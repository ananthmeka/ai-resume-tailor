# =============================================================================
# BACKEND environment (Spring Boot)
# Copy to:  ai-resume-tailor/.env   (project root — same folder as this file)
# Used when: ./scripts/run-cloud-api.sh, ./mvnw spring-boot:run, Railway Docker
#
# NOT used by Vite/React — frontend vars are in frontend/.env.example
# Never commit .env (gitignored).
# =============================================================================

# --- Which LLM? (pick ONE approach) -----------------------------------------
#
# OpenAI is NOT mandatory. If you use Groq (recommended for beta), leave
# OPENAI_API_KEY empty and set SPRING_PROFILES_ACTIVE=groq + GROQ_API_KEY.
#
# A) Groq (cloud, free tier) — recommended for Railway public beta
SPRING_PROFILES_ACTIVE=groq
GROQ_API_KEY=
OPENAI_MODEL=llama-3.3-70b-versatile

# B) OpenAI (paid) — only if you do NOT use profile groq/ollama
# SPRING_PROFILES_ACTIVE=
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# C) Local Ollama on laptop
# SPRING_PROFILES_ACTIVE=ollama
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# OPENAI_MODEL=qwen2.5:7b
# OPENAI_API_KEY=ollama

# --- CORS (browser calls from Vercel or localhost) ---------------------------
APP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-app.vercel.app,https://*.vercel.app

# --- API protection (your secret — same value as frontend VITE_API_KEY) ------
# Local dev: leave APP_API_KEY empty and APP_API_KEY_ENABLED=false
# Railway:   set APP_API_KEY + use profile railway,groq (see DEPLOY-RAILWAY.md)
APP_API_KEY=
APP_API_KEY_ENABLED=false
APP_RATE_LIMIT_PER_MINUTE=30
APP_TAILOR_LIMIT_PER_HOUR=10

# Railway production example (set in Railway dashboard, not necessarily in .env):
# SPRING_PROFILES_ACTIVE=railway,groq
# GROQ_API_KEY=gsk_...
# APP_API_KEY=<output of: openssl rand -hex 32>
# APP_API_KEY_ENABLED=true  (railway profile enables key when APP_API_KEY is set)
